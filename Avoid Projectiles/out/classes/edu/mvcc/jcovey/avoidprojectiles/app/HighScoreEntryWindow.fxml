<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="360.0" prefHeight="180.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.mvcc.jcovey.avoidprojectiles.app.HighScoreEntryWindowController">
    <center>
        <VBox spacing="10.0" style="-fx-padding: 16;">
            <children>
                <Label text="New High Score" style="-fx-font-size: 18px;" />
                <Label fx:id="timeLabel" text="Top 10 time:" />
                <TextField fx:id="initialsField" promptText="ABC" />
                <Label fx:id="validationLabel" textFill="#cc3333" />
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 0 16 16 16;">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" text="Cancel" />
                <Button mnemonicParsing="false" onAction="#handleSave" text="Save" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
